# ─── Supabase ───────────────────────────────────────────────────────────────
# Found in: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (Claude API) ──────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Renderer service (Railway) ──────────────────────────────────────────────
# Set this AFTER deploying apps/renderer to Railway.
# Railway will give you a public URL like: https://appbroda-renderer.up.railway.app
RENDERER_SERVICE_URL=https://your-renderer.up.railway.app
# A secret string you choose — must match RENDERER_SECRET in Railway env vars
RENDERER_SECRET=change-me-to-a-random-string

# ─── Renderer internal (Railway env vars only — do NOT add to Vercel) ────────
PORT=3001
