# These must be set in Railway → your service → Variables

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Must match RENDERER_SECRET in Vercel
RENDERER_SECRET=change-me-to-a-random-string

PORT=3001

# Set automatically by Dockerfile — only needed if overriding the build-time binary
# PRODUCER_HEADLESS_SHELL_PATH=/usr/local/bin/chrome-headless-shell
